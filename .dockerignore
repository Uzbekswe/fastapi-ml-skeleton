# =============================================================
#  .dockerignore
# =============================================================
#  PURPOSE: Control what files Docker sends to the build daemon
#  when you run `docker build`.
#
#  WITHOUT this file, Docker sends EVERYTHING in the project
#  directory as "build context" — including .git (huge), docs
#  (images), tests, .env (secrets!), and poetry.lock (95KB).
#
#  WITH this file, the build context shrinks from ~2MB to ~50KB
#  for this project. Faster builds, smaller attack surface,
#  no secrets leaking into the image layers.
#
#  KEY DIFFERENCE from .gitignore:
#  - .gitignore controls what Git tracks
#  - .dockerignore controls what Docker can see during builds
#  - A file can be Git-tracked but Docker-ignored (e.g. tests/)
#  - They are completely independent systems
# =============================================================

# ── Version control ────────────────────────────────────
# .git/ alone is often 50%+ of build context size
.git
.gitignore

# ── Tests ──────────────────────────────────────────────
# Tests run in CI, not inside the production container.
# Including them adds files the container never executes
# and increases image size for zero benefit.
tests/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Documentation ─────────────────────────────────────
# Docs are for humans reading the repo, not for the
# running service. The PNG screenshots alone are 700KB.
docs/
*.md
LICENSE
MANIFEST

# ── Environment / secrets ─────────────────────────────
# CRITICAL: .env contains API_KEY. If this file enters
# the build context, it can end up baked into an image
# layer — and anyone who pulls the image can extract it.
# The ! pattern whitelists .env.example as documentation.
.env
.env.*
!.env.example

# ── IDE / editor ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Python artifacts ──────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────
.venv/
venv/
env/

# ── Linting / type checking cache ─────────────────────
.mypy_cache/
.ruff_cache/
.flake8

# ── Dev scripts ────────────────────────────────────────
# Linting and test scripts are dev tools, not runtime.
scripts/

# ── Docker files themselves ───────────────────────────
# Prevent recursive inclusion. The Dockerfile and
# compose file are instructions for Docker, not files
# the application needs at runtime.
Dockerfile
docker-compose.yml
.dockerignore

# ── OS files ──────────────────────────────────────────
.DS_Store
Thumbs.db
